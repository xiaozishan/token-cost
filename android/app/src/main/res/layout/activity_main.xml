<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0f1117">

    <!-- Connect Screen -->
    <LinearLayout
        android:id="@+id/connectLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Token Cost"
            android:textSize="28sp"
            android:textColor="#e5e7eb"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="API 余额监控"
            android:textSize="14sp"
            android:textColor="#6b7280"
            android:layout_marginBottom="48dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="服务器地址"
            android:textSize="13sp"
            android:textColor="#9ca3af"
            android:layout_marginBottom="8dp"
            android:layout_gravity="start" />

        <EditText
            android:id="@+id/ipInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="192.168.1.100:3456"
            android:textColor="#e5e7eb"
            android:textColorHint="#6b7280"
            android:background="@drawable/input_bg"
            android:padding="12dp"
            android:inputType="textUri"
            android:autofillHints="" />

        <Button
            android:id="@+id/connectBtn"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:text="连接"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:backgroundTint="#4f46e5" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textSize="13sp"
            android:textColor="#9ca3af" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:text="在运行 Token Cost 的电脑上查看 IP\n在手机浏览器上也可以用 PWA 方式安装"
            android:textSize="12sp"
            android:textColor="#6b7280"
            android:gravity="center"
            android:lineSpacingExtra="4dp" />
    </LinearLayout>

    <!-- WebView -->
    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />
</LinearLayout>
